---
interface Props {
  highlights?: string[];
  scrollTarget: string;
}

const { highlights, scrollTarget } = Astro.props
const hasManyHighlights = highlights && highlights.length > 1
---

{highlights && highlights.length > 0 && (
  <div 
    class="highlights-container" 
    data-expanded="false" 
    data-expandable={hasManyHighlights ? 'true' : 'false'}
    data-scroll-target={scrollTarget}
  >
    <ul class="job-highlights">
      {highlights.map((highlight) => (
        <li>{highlight}</li>
      ))}
    </ul>
    {hasManyHighlights && (
      <button class="expand-btn" aria-label="Expand highlights">
        <span class="btn-text">View all highlights</span>
        <svg 
          class="chevron" 
          viewBox="0 0 24 24" 
          width="16" 
          height="16" 
          stroke="currentColor" 
          stroke-width="2" 
          fill="none" 
          stroke-linecap="round" 
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
    )}
  </div>
)}

<script>
import { initiateHighlightAccordions } from '../../helpers/initiate-highlight-accordions'

function handleScroll(e: any) {
  const { target } = e.detail
  const scrollTarget = target ? document.querySelector(target) : null
  if (scrollTarget) {
    const headerOffset = 100
    const elementPosition = scrollTarget.getBoundingClientRect().top
    const offsetPosition = elementPosition + window.pageYOffset - headerOffset
    window.scrollTo({
      top: offsetPosition,
      behavior: 'smooth'
    })
  }
}

function initialize() {
  initiateHighlightAccordions()
  document.querySelectorAll('.highlights-container').forEach(c => {
    c.addEventListener('highlights-collapsed', handleScroll)
  })
}

initialize()
document.addEventListener('astro:after-swap', initialize)
</script>

<style lang="scss">
  @use "../../styles/mixins" as *;

  .highlights-container {
    position: relative;
    margin-bottom: var(--spacing-lg);

    &[data-expandable="true"] {
      &[data-expanded="false"] {
        .job-highlights {
          /* Increased height to avoid clipping early on mobile */
          max-height: 10rem;
          margin-bottom: 0;
          overflow: hidden;

          /* Subtle mask at the very bottom */
          padding-bottom: 2rem;
          mask-image: linear-gradient(
            to bottom,
            var(--color-text) calc(100% - 2.5rem),
            transparent 100%
          );
        }
      }

      &[data-expanded="true"] {
        .job-highlights {
          max-height: 125rem;
          margin-bottom: 0;

          /* Remove mask when content is fully visible */
          mask-image: none;
        }

        .chevron {
          transform: rotate(180deg);
        }
      }
    }
  }

  .job-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    transition: max-height 0.4s ease-in-out;
    transition-delay: 0.1s;
    overflow: hidden;

    li {
      position: relative;
      padding-left: 1.5rem;
      margin-bottom: var(--spacing-xs);
      font-size: var(--font-size-sm);
      line-height: 1.6;
      color: var(--color-text-muted);

      &::before {
        content: "→";
        position: absolute;
        left: 0;
        color: var(--color-primary);
        font-weight: bold;
        transition: transform 0.3s ease;
      }

      &:hover::before {
        transform: translateX(0.1rem);
      }
    }
  }

  .expand-btn {
    @include meta-text(var(--color-primary));

    margin-top: 0.5rem;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
    font-family: inherit;

    &:hover {
      opacity: 0.8;
    }

    .chevron {
      transition: transform 0.3s ease;
    }
  }
</style>
