---
interface Props {
  role: string;
  company: string;
  logoUrl?: string;
  logoAdaptive?: boolean;
  description?: string;
}

const { role, company, logoUrl, logoAdaptive, description } = Astro.props;
---

<div class="job-header">
  {logoUrl && (
    <div class="company-logo-wrapper">
      <div 
        class:list={['company-logo', { 'adaptive-logo': logoAdaptive }]}
        role="img"
        aria-label={company}
        style={logoAdaptive ? `--logo-url: url(${logoUrl})` : undefined}
      >
        {!logoAdaptive && <img src={logoUrl} alt={company} />}
      </div>
    </div>
  )}
  <div class="role-company">
    <h3 class="job-role">{role}</h3>
    <span class="job-company">{company}</span>
  </div>
</div>

{description && (
  <p class="job-description">{description}</p>
)}

<style lang="scss">
  @use "../../styles/mixins" as *;

  .job-header {
    display: flex;
    flex-flow: row wrap;
    justify-content: flex-start;
    align-items: center;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-md);

    @include mobile-only {
      gap: var(--spacing-md);
      flex-flow: row nowrap;
    }
  }

  .role-company {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    min-width: 0;
  }

  .job-role {
    @include sub-title-h2;

    margin-bottom: 0.5rem;
  }

  .company-logo-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 5rem;
    height: 5rem;
    transition: transform 0.4s ease;

    @include mobile-only {
      width: 3.5rem;
      height: 3.5rem;
    }

    // Bind to the hovered state of the outer card wrapper globally
    :global(.job-card:hover) & {
      transform: scale(1.05);
    }
  }

  .company-logo {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;

    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      filter: grayscale(1);
      opacity: 0.8;
      transition: all 0.3s ease;
    }

    &.adaptive-logo {
      background-color: var(--color-text);
      opacity: 0.8;
      mask-image: var(--logo-url);
      mask-size: contain;
      mask-repeat: no-repeat;
      mask-position: center;
    }
    
    :global(.job-card:hover) & {
      opacity: 1;
      
      img {
        filter: grayscale(0);
        opacity: 1;
      }

      &.adaptive-logo {
        /* Pop to primary color on hover! */
        background-color: var(--color-primary);
      }
    }
  }

  .job-company {
    @include sub-title-h3;
  }

  .job-description {
    @include body-text;

    margin-bottom: var(--spacing-md);
    opacity: 0.9;
  }
</style>
