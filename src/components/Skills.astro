---
import { getEntry } from 'astro:content'
import Section from './Section.astro'
import determineFullExperiencePoints
  from '../helpers/determine-full-experience-points'
import SkillItem from './SkillItem.astro'

const skillsEntry = await getEntry('skills', 'data')
const categories = skillsEntry?.data?.categories || []

const fullExperiencePoints = determineFullExperiencePoints(
  categories.flatMap((category) => category.items)
)
---

<Section id="skills" class="skills-section">
  <div class="section-header">
    <h2 class="section-title">Skills</h2>
    <div class="title-underline"></div>
  </div>

  <div class="skills-grid">
    {
      categories.map((category) => (
        <div class="skill-category reveal reveal-stagger" data-state="closed">
          <div class="category-header">
            <h3 class="category-name">{category.name}</h3>
            <div class="category-chevron"></div>
          </div>
          <div class="category-body">
            <div class="body-wrapper">
              <ul class="skill-list">
                {category.items.map((item) => (
                  <li
                    class:list={[
                      'skill-item-group',
                      { 'has-children': !!item.children },
                    ]}
                    data-state="closed"
                  >
                    <div class="parent-item">
                      <SkillItem 
                        {...item} 
                        fullExperiencePoints={fullExperiencePoints}
                      >
                        {item.children && (
                          <span slot="chevron" class="item-chevron" />
                        )}
                      </SkillItem>
                    </div>

                    {item.children && (
                      <div class="child-items-container">
                        <ul class="child-list">
                          {item.children.map((child) => (
                            <li>
                              <SkillItem 
                                {...child} 
                                fullExperiencePoints={fullExperiencePoints} 
                                isChild={true} 
                              />
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</Section>

<script>
const initSkills = () => {
  // Handle Category Expansion
  const categories = document.querySelectorAll('.skill-category')
  categories.forEach(category => {
    category.addEventListener('click', () => {
      const isCurrentlyOpen = category.getAttribute('data-state') === 'open'
      category.setAttribute('data-state', isCurrentlyOpen ? 'closed' : 'open')
    })
  })

  // Handle Nested Skill Expansion
  const parentItems = document.querySelectorAll('.parent-item')
  parentItems.forEach(parent => {
    parent.addEventListener('click', (e) => {
      // Avoid triggering category close when clicking a sub-skill
      e.stopPropagation()
      const group = parent.closest('.skill-item-group')
      if (!group) return
      const isCurrentlyOpen = group.getAttribute('data-state') === 'open'
      group.setAttribute('data-state', isCurrentlyOpen ? 'closed' : 'open')
    })
  })
}

initSkills()
document.addEventListener('astro:after-swap', initSkills)
</script>


<style lang="scss">
  @use "sass:list";
  @use "../styles/mixins" as *;

  $category-colours: (
    var(--color-secondary),
    var(--color-tertiary),
    var(--color-quaternary)
  );

  .skills-section {
    background-color: var(--color-surface);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--spacing-sm);
  }

  .title-underline {
    width: 4rem;
    height: 0.25rem;
    background-color: var(--color-primary);
    margin: 0 auto;
    border-radius: 0.125rem;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);

    @include tablet {
      display: block;
      column-count: 2;
      column-gap: var(--spacing-2xl);
    }

    @include desktop {
      column-count: 3;
    }
  }

  .skill-category {
    padding: var(--spacing-lg);
    background-color: var(--color-surface);
    backdrop-filter: blur(0.625rem);
    border: 0.0625rem solid var(--color-border);
    border-radius: 1.5rem;
    box-shadow: 0 0.5rem 2rem var(--color-shadow);
    transition:
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      box-shadow 0.3s ease;

    @include tablet {
      display: inline-block;
      width: 100%;
      break-inside: avoid;
      margin-bottom: var(--spacing-2xl);
    }

    @for $i from 1 through 3 {
      &:nth-child(3n + #{$i}) {
        background-color: #{list.nth($category-colours, $i)};
      }
    }

    &:hover {
      transform: translateY(-0.75rem);
      box-shadow: 0 0.9375rem 2.8125rem var(--color-shadow);
    }

    &[data-state="open"] {
      .category-body {
        grid-template-rows: 1fr;
      }

      .category-chevron {
        transform: rotate(180deg);
        border-color: var(--color-primary);

        &::after {
          border-color: var(--color-bg);
        }
      }
    }
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    cursor: pointer;
  }

  .category-name {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-bg);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .category-chevron {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;

    &::after {
      content: "";
      width: 1rem;
      height: 1rem;
      border-right: 0.125rem solid var(--color-bg);
      border-bottom: 0.125rem solid var(--color-bg);
      transform: translateY(-0.1rem) rotate(45deg);
      transition: border-color 0.3s ease;
    }
  }

  .category-body {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    .body-wrapper {
      min-height: 0;
    }
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding-top: var(--spacing-xl);
  }

  .skill-item-group {
    list-style: none;
    
    &.has-children {
      .parent-item {
        cursor: pointer;
        
        &:hover {
          :global(.skill-name) {
            color: var(--color-primary);
          }
        }
      }
    }

    &[data-state="open"] {
      .child-items-container {
        grid-template-rows: 1fr;
        margin-bottom: var(--spacing-sm);
      }

      .item-chevron {
        transform: rotate(180deg);
        
        &::after {
          border-color: var(--color-primary);
        }
      }
    }
  }

  .item-chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: var(--spacing-xs);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    vertical-align: middle;
    width: 0.75rem;
    height: 0.75rem;

    &::after {
      content: "";
      width: 0.4rem;
      height: 0.4rem;
      border-right: 0.125rem solid var(--color-bg);
      border-bottom: 0.125rem solid var(--color-bg);
      transform: translateY(-0.05rem) rotate(45deg);
      transition: all 0.3s ease;
    }
  }

  .child-items-container {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .child-list {
    min-height: 0;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    
    li {
      list-style: none;
    }
  }
</style>
