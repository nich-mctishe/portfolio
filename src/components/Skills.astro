---
import { getEntry } from 'astro:content'
import Section from './Section.astro'
import getSkillDuration from '../helpers/get-skill-duration'
import determineFullExperiencePoints from '../helpers/determine-full-experience-points'

const skillsEntry = await getEntry('skills', 'data')
const categories = skillsEntry?.data?.categories || []

const getDuration = (since: number, end?: number): string => {
  const skillDuration = getSkillDuration(since, end)
  const suffix = skillDuration === 1 ? 'yr' : 'yrs'

  return skillDuration + suffix
}

const fullExperiencePoints = determineFullExperiencePoints(
  categories.flatMap((category) => category.items)
)
---

<Section id="skills" class="skills-section">
  <div class="section-header">
    <h2 class="section-title">Skills</h2>
    <div class="title-underline"></div>
  </div>

  <div class="skills-grid">
    {
      categories.map((category) => (
        <div class="skill-category reveal reveal-stagger" data-state="closed">
          <div class="category-header">
            <h3 class="category-name">{category.name}</h3>
            <div class="category-chevron"></div>
          </div>
          <div class="category-body">
            <div class="body-wrapper">
              <ul class="skill-list">
                {category.items.map((item) => {
                  const duration = getSkillDuration(item.since, item.end)
                  const dTotal = fullExperiencePoints
                  const dFilled = duration
                  const mTotal = 10
                  const mFilled = Math.max(1, Math.round((duration / fullExperiencePoints) * mTotal))
                  
                  return (
                    <li class={`skill-item-group ${item.children ? 'has-children' : ''}`} data-state="closed">
                      <div class="skill-item parent-item">
                        <p class="skill-name">
                          {item.name}
                          {item.children && <span class="item-chevron"></span>}
                        </p>
                        <div class="skill-bar">
                          <div class="segments desktop-only" style={`--total: ${dTotal}; --filled: ${dFilled}`}>
                            <div class="bar-track">{"=".repeat(dTotal)}</div>
                            <div class="bar-fill">{"=".repeat(dFilled)}</div>
                          </div>
                          <div class="segments mobile-only" style={`--total: ${mTotal}; --filled: ${mFilled}`}>
                            <div class="bar-track">{"=".repeat(mTotal)}</div>
                            <div class="bar-fill">{"=".repeat(mFilled)}</div>
                          </div>
                        </div>
                        <small class="skill-duration">
                          {getDuration(item.since, item.end)}
                        </small>
                      </div>

                      {item.children && (
                        <div class="child-items-container">
                          <ul class="child-list">
                            {item.children.map((child) => {
                              const cDuration = getSkillDuration(child.since, child.end)
                              const cdTotal = fullExperiencePoints
                              const cdFilled = cDuration
                              const cmTotal = 10
                              const cmFilled = Math.max(1, Math.round((cDuration / fullExperiencePoints) * mTotal))
                              
                              return (
                                <li class="skill-item is-child">
                                  <p class="skill-name">{child.name}</p>
                                  <div class="skill-bar">
                                    <div class="segments desktop-only" style={`--total: ${cdTotal}; --filled: ${cdFilled}`}>
                                      <div class="bar-track">{"=".repeat(cdTotal)}</div>
                                      <div class="bar-fill">{"=".repeat(cdFilled)}</div>
                                    </div>
                                    <div class="segments mobile-only" style={`--total: ${cmTotal}; --filled: ${cmFilled}`}>
                                      <div class="bar-track">{"=".repeat(cmTotal)}</div>
                                      <div class="bar-fill">{"=".repeat(cmFilled)}</div>
                                    </div>
                                  </div>
                                  <small class="skill-duration">
                                    {getDuration(child.since, child.end)}
                                  </small>
                                </li>
                              )
                            })}
                          </ul>
                        </div>
                      )}
                    </li>
                  )
                })}
              </ul>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</Section>

<script>
  const initSkills = () => {
    // Handle Category Expansion
    const headers = document.querySelectorAll('.category-header');
    headers.forEach(header => {
      header.addEventListener('click', () => {
        const category = header.closest('.skill-category');
        if (!category) return;
        const isCurrentlyOpen = category.getAttribute('data-state') === 'open';
        category.setAttribute('data-state', isCurrentlyOpen ? 'closed' : 'open');
      });
    });

    // Handle Nested Skill Expansion
    const parentItems = document.querySelectorAll('.parent-item');
    parentItems.forEach(parent => {
      parent.addEventListener('click', (e) => {
        e.stopPropagation(); // Avoid triggering category close when clicking a sub-skill
        const group = parent.closest('.skill-item-group');
        if (!group) return;
        const isCurrentlyOpen = group.getAttribute('data-state') === 'open';
        group.setAttribute('data-state', isCurrentlyOpen ? 'closed' : 'open');
      });
    });
  };

  initSkills();
  document.addEventListener('astro:after-swap', initSkills);
</script>


<style lang="scss">
  @use "sass:list";
  @use "../styles/mixins" as *;

  $category-colours: (
    var(--color-secondary),
    var(--color-tertiary),
    var(--color-quaternary)
  );

  .skills-section {
    background-color: var(--color-surface);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--spacing-sm);
  }

  .title-underline {
    width: 4rem;
    height: 0.25rem;
    background-color: var(--color-primary);
    margin: 0 auto;
    border-radius: 0.125rem;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl);

    @include tablet {
      display: block;
      column-count: 2;
      column-gap: var(--spacing-2xl);
    }

    @include desktop {
      column-count: 3;
    }
  }

  .skill-category {
    padding: var(--spacing-lg);
    background-color: var(--color-surface);
    backdrop-filter: blur(0.625rem);
    border: 0.0625rem solid var(--color-border);
    border-radius: 1.5rem;
    box-shadow: 0 0.5rem 2rem var(--color-shadow);
    transition:
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      box-shadow 0.3s ease;

    @include tablet {
      display: inline-block;
      width: 100%;
      break-inside: avoid;
      margin-bottom: var(--spacing-2xl);
    }

    @for $i from 1 through 3 {
      &:nth-child(3n + #{$i}) {
        background-color: #{list.nth($category-colours, $i)};
      }
    }

    &:hover {
      transform: translateY(-0.75rem);
      box-shadow: 0 0.9375rem 2.8125rem var(--color-shadow);
    }

    &[data-state="open"] {
      .category-body {
        grid-template-rows: 1fr;
      }

      .category-chevron {
        transform: rotate(180deg);
        border-color: var(--color-primary);

        &::after {
          border-color: var(--color-bg);
        }
      }
    }
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    cursor: pointer;
  }

  .category-name {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--color-bg);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .category-chevron {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;

    &::after {
      content: "";
      width: 1rem;
      height: 1rem;
      border-right: 0.125rem solid var(--color-bg);
      border-bottom: 0.125rem solid var(--color-bg);
      transform: translateY(-0.1rem) rotate(45deg);
      transition: border-color 0.3s ease;
    }
  }

  .category-body {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.4s cubic-bezier(0.4, 0, 0.2, 1);

    .body-wrapper {
      min-height: 0;
    }
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding-top: var(--spacing-xl);
  }

  .skill-item-group {
    list-style: none;
    
    &.has-children {
      .parent-item {
        cursor: pointer;
        
        &:hover {
          .skill-name {
            color: var(--color-primary);
          }
        }
      }
    }
  }

  .skill-item {
    display: grid;
    grid-template-columns: 1fr 6.5rem 2rem;
    width: 100%;
    align-items: flex-start;
    gap: var(--spacing-sm);
    color: var(--color-bg);
    font-size: 0.8125rem;
    font-weight: 500;
    transition: all 0.25s ease;

    @include tablet {
      grid-template-columns: 1fr auto 2.5rem;
      gap: var(--spacing-md);
      align-items: center;
    }

    .skill-name {
      display: flex;
      align-items: center;
      line-height: 1.25;
      word-wrap: break-word;
      min-width: 0;
    }

    &.is-child {
      padding-left: var(--spacing-md);
      opacity: 0.85;
      font-size: 0.75rem;
      margin-top: var(--spacing-xs);

      .skill-bar {
        font-size: 0.9rem;
      }
    }
  }

  .item-chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: var(--spacing-xs);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    vertical-align: middle;
    width: 0.75rem;
    height: 0.75rem;

    &::after {
      content: "";
      width: 0.4rem;
      height: 0.4rem;
      border-right: 0.125rem solid var(--color-bg);
      border-bottom: 0.125rem solid var(--color-bg);
      transform: translateY(-0.05rem) rotate(45deg);
      transition: all 0.3s ease;
    }
  }

  .skill-item-group[data-state="open"] {
    .child-items-container {
      grid-template-rows: 1fr;
      margin-bottom: var(--spacing-sm);
    }
    .item-chevron {
      transform: rotate(180deg);
      
      &::after {
        border-color: var(--color-primary);
      }
    }
  }

  .child-items-container {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .child-list {
    min-height: 0;
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .skill-bar {
    position: relative;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    letter-spacing: -0.1em;
    font-weight: 700;
    font-size: 1.1rem;
    line-height: 1;
    height: 1.1rem; // Match font-size

    .segments {
      position: relative;
      display: none; // Default hidden, toggled by mobile/desktop classes below

      &.mobile-only { display: block; }
      @include tablet {
        &.desktop-only { display: block; }
        &.mobile-only { display: none; }
      }
    }

    .bar-track {
      color: var(--color-bg);
      opacity: 0.2;
      white-space: nowrap;
    }

    .bar-fill {
      position: absolute;
      top: 0;
      left: 0;
      color: var(--color-primary);
      white-space: nowrap;
      overflow: hidden;
      width: 0; // Start at 0
      
      // Stealth Exit: Stay filled until tile collapses
      transition: width 0s 0.5s; 
    }
  }

  // Thermometer Filling Trigger
  .skill-category[data-state="open"] {
    .bar-fill {
      // Calculate width based on (filled / total)
      width: calc((var(--filled) / var(--total)) * 100%);
      
      // Smooth liquid transition (2 seconds as requested)
      transition: width 2s cubic-bezier(0.4, 0, 0.2, 1);
      transition-delay: 0.1s; // Start almost immediately
    }
  }

  .skill-duration {
    font-size: 0.7rem;
    color: var(--color-bg);
    font-weight: 400;
    transition: color 0.25s ease;
    text-align: right;
  }
</style>
