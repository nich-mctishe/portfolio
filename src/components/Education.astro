---
import { getEntry } from 'astro:content'
import Section from './Section.astro'

const educationEntry = await getEntry('education', 'data')
const qualifications = educationEntry?.data?.qualifications || []
---

<Section id="education" class="education-section">
  <div class="section-header">
    <h2 class="section-title">Education</h2>
    <div class="title-underline"></div>
  </div>

  <div class="education-grid">
    {
      qualifications.map((edu) => (
        <div class="education-card reveal reveal-stagger">
          <h3 class="degree">{edu.degree}</h3>
          <p class="institution">{edu.institution}</p>
          <span class="year">{edu.year}</span>
        </div>
      ))
    }
  </div>
</Section>

<style lang="scss">
  @use "../styles/mixins" as *;

  .education-section {
    background-color: var(--color-bg);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-title {
    @include main-title;
    margin-bottom: var(--spacing-sm);
  }

  .title-underline {
    width: 4rem;
    height: 0.25rem;
    background-color: var(--color-primary);
    margin: 0 auto;
    border-radius: 0.125rem;
  }

  .education-grid {
    @include grid-responsive(1, 2, 2, var(--spacing-xl));
    max-width: 50rem;
    margin: 0 auto;
  }

  .education-card {
    @include card-base(var(--spacing-2xl) var(--spacing-xl));
    text-align: center;
    @include hover-lift(-0.5rem);
  }

  .degree {
    @include sub-title-h3;
    margin-bottom: var(--spacing-sm);
  }

  .institution {
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: var(--spacing-md);
  }

  .year {
    @include pill-text;
    color: var(--color-text-muted);
  }
</style>
