---
import { getEntry } from 'astro:content'
import Section from './Section.astro'
import ExpandableButton from './general/ExpandableButton.astro'

const educationEntry = await getEntry('education', 'data')
const qualifications = (educationEntry?.data?.qualifications || [])
  .filter(q => q.active !== false);
---

<Section id="education" class="education-section">
  <div class="section-header">
    <h2 class="section-title">Education</h2>
    <div class="title-underline"></div>
  </div>

  <div class="education-container">
    {
      qualifications.map((edu, index) => (
        <div 
          class="education-card reveal reveal-stagger" 
          data-expandable={!!edu.synopsis}
          data-expanded="false"
        >
          <div class="card-main">
            {edu.logoUrl && (
              <div class="logo-wrapper">
                <div 
                  class:list={[
                    'edu-logo', 
                    { 'adaptive-logo': edu.logoAdaptive }
                  ]}
                  role="img"
                  aria-label={edu.institution}
                  style={edu.logoAdaptive 
                    ? `--logo-url: url(${edu.logoUrl})` 
                    : undefined}
                >
                  {!edu.logoAdaptive && (
                    <img src={edu.logoUrl} alt={edu.institution} />
                  )}
                </div>
              </div>
            )}
            <div class="edu-content">
              <div class="edu-meta">
                <h3 class="degree">{edu.degree}</h3>
                <span class="year">{edu.year}</span>
              </div>
              <p class="institution">{edu.institution}</p>
              {edu.location && <span class="location">{edu.location}</span>}
            </div>
          </div>

          {edu.synopsis && (
            <div class="expansion-content">
              <div class="synopsis-wrapper">
                <p class="synopsis">{edu.synopsis}</p>
              </div>
              <ExpandableButton text="View synopsis" ariaLabel="Toggle synopsis" class="edu-expand-btn" />
            </div>
          )}
        </div>
      ))
    }
  </div>
</Section>

<script>
import { initiateEducationAccordions } from '../helpers/initiate-education-accordions'

initiateEducationAccordions()
document.addEventListener('astro:after-swap', () => initiateEducationAccordions())
</script>

<style lang="scss">
  @use "../styles/mixins" as *;

  .education-section {
    background-color: var(--color-bg);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
  }
  
  .section-title {
    @include main-title;

    margin-bottom: var(--spacing-sm);
  }
  
  .title-underline {
    width: 4rem;
    height: 0.25rem;
    background-color: var(--color-primary);
    margin: 0 auto;
    border-radius: 0.125rem;
  }
  
  .education-container {
    max-width: 50rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
  }
  
  .education-card {
    @include card-base(var(--spacing-xl));
    @include hover-lift(-0.25rem);
    
    &[data-expanded="true"] {
      border-color: var(--color-primary-light, var(--color-primary));
      
      :global(.chevron) {
        transform: rotate(180deg);
      }
      
      .synopsis-wrapper {
        grid-template-rows: 1fr;
        opacity: 1;
        margin-top: var(--spacing-lg);
      }
    }
  }
  
  .card-main {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
    
    @include mobile-only {
      gap: var(--spacing-md);
    }
  }
  
  .logo-wrapper {
    width: 3.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    
    @include mobile-only {
      width: 3rem;
      height: 3rem;
    }
    
    img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }
  
  .edu-logo {
    width: 100%;
    height: 100%;
    
    &.adaptive-logo {
      background-color: var(--color-text);
      opacity: 0.8;
      mask-image: var(--logo-url);
      mask-size: contain;
      mask-repeat: no-repeat;
      mask-position: center;
      transition: all 0.3s ease;
    }
  }
  
  .education-card:hover {
    .edu-logo.adaptive-logo {
      background-color: var(--color-primary);
      opacity: 1;
    }
  }
  
  .edu-content {
    flex: 1;
    min-width: 0;
  }
  
  .edu-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-md);
    margin-bottom: 0.25rem;
    
    @include mobile-only {
      flex-direction: column;
      gap: 0.125rem;
    }
  }
  
  .degree {
    @include sub-title-h3;

    line-height: var(--line-height-normal);
  }
  
  .year {
    @include small-meta;

    color: var(--color-primary);
  }
  
  .institution {
    @include body-text(var(--font-size-sm), var(--color-text-muted));

    font-weight: var(--font-weight-medium);
    margin-bottom: 0.125rem;
  }
  
  .location {
    @include small-meta;

    opacity: 0.7;
  }
  
  .synopsis-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .synopsis {
    min-height: 0;

    @include body-text(var(--font-size-sm));

    line-height: var(--line-height-semi-loose);
    padding-bottom: var(--spacing-lg);
    border-bottom: 0.0625rem solid var(--color-border);
  }
  
  :global(.edu-expand-btn) {
    margin-top: var(--spacing-md);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    
    &:hover {
      background-color: var(--color-surface-hover);
    }
  }
</style>

