---
import { getEntry } from 'astro:content'
import ThemeToggle from './ThemeToggle.astro'

const personalEntry = await getEntry('personal', 'data')
const personal = personalEntry?.data || { 
  name: 'Name', 
  title: 'Title', 
  showThemeToggle: false 
}

const nameParts = personal.name.split(' ')
const titleParts = personal.title.split(' & ')

const navItems = [
  { label: 'Skills', href: '#skills' },
  { label: 'Work', href: '#experience' },
  { label: 'Edu', href: '#education' },
  { label: 'Clients', href: '#clients' },
];
---

<header class="site-header">
  <div class="header-content">
    <div class="brand">
      <div class="brand-text">
        <div class="brand-circle"></div>
        <div class="branding">
          <h1 class="name">
            {nameParts.map((part) => <span>{part}</span>)}
          </h1>
          <p class="title">
            <span>{titleParts[0]} &</span>
            <span>{titleParts[1]}</span>
          </p>
        </div>
      </div>
    </div>

    <div class="controls">
      <nav class="bubble-nav" aria-label="Main Navigation">
        <button class="hamburger" aria-label="Open Menu" aria-expanded="false">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
        <ul class="nav-list">
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} class="nav-bubble">
                  <span class="nav-label">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      {personal.showThemeToggle && <ThemeToggle />}
    </div>
  </div>
</header>

<style lang="scss">
  @use "../styles/mixins" as *;

  .site-header {
    padding: var(--spacing-md) var(--spacing-lg);
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-surface);
    backdrop-filter: blur(0.75rem);
    border-bottom: 0.0625rem solid var(--color-border);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 90rem;
    margin: 0 auto;
  }

  .brand {
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;

    &:hover {
      opacity: 0.8;
    }
  }

  .brand-circle {
    min-width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--color-primary);
    border: 0.0625rem solid #ffffff33;
    box-shadow: 0 0.25rem 0.625rem var(--color-shadow);
  }

  .brand-text {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .branding {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--spacing-md);
  }

  .name {
    display: flex;
    flex-direction: column;
    padding-left: 0;

    @include name(var(--font-size-lg), 0.85);
  }

  .title {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding-left: var(--spacing-md);
    border-left: 0.0625rem solid var(--color-border);

    @include role(0.85rem, 1.2);

    color: var(--color-primary);

    @include mobile-only {
      display: none;
    }
  }

  .controls {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .bubble-nav {
    display: flex;
    align-items: center;
  }

  .hamburger {
    display: block;
    width: 2rem;
    height: 2rem;
    position: relative;
    z-index: 110;
    cursor: pointer;
    background: transparent;
    border: none;
    padding: 0;

    @include tablet {
      display: none;
    }

    .hamburger-line {
      display: block;
      width: 100%;
      height: 0.125rem;
      background-color: var(--color-text);
      margin: 0.375rem 0;
      transition:
        transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
        opacity 0.3s ease;
      transform-origin: center;
    }

    /* stylelint-disable-next-line selector-pseudo-class-no-unknown */
    :global(.bubble-nav.is-open) & {
      .hamburger-line:nth-child(1) {
        transform: translateY(0.5rem) rotate(45deg);
      }

      .hamburger-line:nth-child(2) {
        opacity: 0;
      }

      .hamburger-line:nth-child(3) {
        transform: translateY(-0.5rem) rotate(-45deg);
      }
    }
  }

  .nav-list {
    display: none; // Hidden on mobile by default
    flex-direction: column;
    position: absolute;
    top: 100%;
    right: 0;
    padding: var(--spacing-lg);
    gap: var(--spacing-md);

    /* stylelint-disable-next-line selector-pseudo-class-no-unknown */
    :global(nav.is-open) & {
      display: flex;
    }

    @include tablet {
      display: flex;
      flex-direction: row;
      position: static;
      background: transparent;
      border: none;
      padding: 0;
      backdrop-filter: none;
    }

    li {
      &:nth-child(2) .nav-bubble {
        background-color: var(--color-tertiary);
      }

      &:nth-child(3) .nav-bubble {
        background-color: var(--color-quaternary);
      }


      @for $i from 1 through 5 {
        &:nth-child(#{$i}) .nav-bubble {
          animation-delay: #{$i * 0.1}s;
        }
      }
    }
  }

  .nav-bubble {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background-color: var(--color-secondary);
    color: var(--color-bg);
    text-decoration: none;
    font-weight: 700;
    font-size: var(--font-size-xs);
    border: 0.0625rem solid #ffffff33;
    box-shadow: 0 0.25rem 0.9375rem var(--color-shadow);
    animation: nav-float 6s ease-in-out infinite;
    transition:
      transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      background-color 0.3s ease,
      box-shadow 0.3s ease;

    &:hover {
      transform: translateY(-0.5rem) scale(1.1);
      box-shadow: 0 0.625rem 1.5625rem var(--color-shadow);
      background-color: var(--color-primary);
      animation-play-state: paused;
    }
  }

  @keyframes nav-float {
    0%,
    100% {
      transform: translateY(0) rotate(0);
    }

    50% {
      transform: translateY(-0.5rem) rotate(3deg);
    }
  }
</style>

<script>
class MobileNav {
  constructor() {
    const nav = document.querySelector('.bubble-nav')
    const btn = document.querySelector('.hamburger')

    if (btn && nav) {
      btn.addEventListener('click', () => {
        const isExpanded = btn.getAttribute('aria-expanded') === 'true'
        btn.setAttribute('aria-expanded', (!isExpanded).toString())
        nav.classList.toggle('is-open')
      })
    }
  }
}

new MobileNav()

document.addEventListener('astro:after-swap', () => {
  new MobileNav()
})
</script>
