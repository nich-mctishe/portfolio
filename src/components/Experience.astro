---
import { getEntry } from 'astro:content'
import Section from './Section.astro'
import ExperienceItem from './experience/ExperienceItem.astro'

const experienceEntry = await getEntry('experience', 'data')
const jobs = experienceEntry?.data?.jobs || [];
---

<Section id="experience" class="experience-section">
  <div class="section-header reveal">
    <h2 class="section-title">Work Experience</h2>
    <div class="title-underline"></div>
  </div>

  <div class="timeline">
    {
      jobs.map((job, index) => (
        <ExperienceItem job={job} index={index} />
      ))
    }
  </div>
</Section>

<style lang="scss">
  @use "../styles/mixins" as *;

  .experience-section {
    background-color: var(--color-bg);
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
  }

  .section-title {
    @include main-title;
    margin-bottom: var(--spacing-sm);
  }

  .title-underline {
    width: 3rem;
    height: 0.3125rem;
    background: var(--color-primary);
    margin: 0 auto;
    border-radius: 1rem;
  }

  .timeline {
    position: relative;
    max-width: 65rem;
    margin: 0 auto;
    padding-left: 14rem; // Space for dates on Desktop/Tablet

    @include mobile-only {
      padding-left: 2rem;
    }

    &::before {
      content: "";
      position: absolute;
      left: 12.8rem; // Center point for the line
      top: 0;
      bottom: 1rem;
      width: 0.125rem;
      background: linear-gradient(
        to bottom,
        transparent,
        var(--color-primary),
        var(--color-primary),
        transparent
      );
      opacity: 1;

      @include mobile-only {
        left: 0.8125rem;
      }
    }
  }
</style>
