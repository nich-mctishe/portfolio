---
import { getEntry } from 'astro:content'
import Section from './Section.astro'

const clientsEntry = await getEntry('clients', 'data')
const clients = clientsEntry?.data?.clients || [];
---

<Section id="clients" class="clients-section">
  <div class="section-header">
    <h2 class="section-title">Global Client Highlights</h2>
    <div class="title-underline"></div>
  </div>

  <div class="clients-grid">
    {
      clients.map((client) => (
        <div class="client-card reveal reveal-stagger">
          <div class="client-logo-placeholder">
            {client.logoUrl && (
              <img src={client.logoUrl} alt={client.name} />
            )}
            {!client.logoUrl && (
              <span class="client-name">{client.name}</span>
            )}
          </div>
        </div>
      ))
    }
  </div>
</Section>

<style lang="scss">
  @use "../styles/mixins" as *;

  .clients-section {
    background-color: var(--color-surface);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
  }

  .section-title {
    @include main-title;
    margin-bottom: var(--spacing-sm);
  }

  .title-underline {
    width: 4rem;
    height: 0.25rem;
    background-color: var(--color-primary);
    margin: 0 auto;
    border-radius: 0.125rem;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);

    @include tablet {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-xl);
    }

    @include desktop {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .client-card {
    aspect-ratio: 3 / 2;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: var(--color-surface);
    border: 0.0625rem solid var(--color-border);
    border-radius: 1rem;
    padding: var(--spacing-md);
    @include hover-lift(-0.5rem, var(--color-shadow));
    filter: grayscale(1);
    opacity: 0.8;

    &:hover {
      filter: grayscale(0);
      opacity: 1;
      transform: translateY(-0.5rem) scale(1.05); // user had scale here too. 
      border-color: var(--color-primary);
      background-color: var(--color-bg);
    }

    .client-logo-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      justify-content: center;
      align-items: center;

      img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }
    }
  }

  .client-name {
    @include pill-text;
    text-align: center;
    color: var(--color-text-muted);
    transition: color 0.3s ease;

    .client-card:hover & {
      color: var(--color-primary);
    }
  }
</style>
