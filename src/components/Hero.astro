---
import { getEntry } from 'astro:content'
import Section from './Section.astro'

const personalEntry = await getEntry('personal', 'data')
const personal = personalEntry?.data || {
  name: 'Name',
  title: 'Title',
  description: 'Description',
  email: 'Email',
  location: 'Location',
  socials: [],
};
---

<Section id="hero" class="hero-section">
  <div class="hero-content">
    <div class="text-wrapper">
      <p>{personal.description}</p>
      <div class="cta-wrapper">
        {personal.socials.map((social) => (
          <a
            href={social.url}
            class="cta-button"
            target="_blank"
            rel="noopener noreferrer"
          >
            <img src={social.icon} alt={social.platform} class="social-icon" />
          </a>
        ))}
      </div>
    </div>

    <div class="visual-wrapper">
      <div class="bubble bubble-1"></div>
      <div class="bubble bubble-2"></div>
      <div class="bubble bubble-3"></div>
      <div class="bubble-large">
        <h1 class="name">{personal.name}</h1>
        <p class="role">{personal.title}</p>
      </div>
    </div>
  </div>
</Section>

<style lang="scss">
  @use "../styles/mixins" as *;

  .hero-section {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    background: radial-gradient(
      circle at 70% 30%,
      var(--color-surface) 0%,
      var(--color-bg) 100%
    );
    overflow: hidden;
  }

  .hero-content {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    justify-content: space-around;
    position: relative;
    z-index: 10;

    @include tablet {
      grid-template-columns: 1.2fr 0.8fr;
      flex-direction: row;
    }
  }

  .name {
    @include name;

    margin-bottom: var(--spacing-md);
  }

  .role {
    @include role(var(--font-size-xl));

    margin-bottom: var(--spacing-2xl);
    max-width: 35rem;

    // Override uppercase from mixin for Hero section if needed
    text-transform: none;
  }

  .text-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);

    p {
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      font-family: var(--font-body);
      margin-bottom: var(--spacing-xl);
      margin-right: var(--spacing-xl);
      max-width: 35rem;
      white-space: break-spaces;
    }

    @include tablet {
      align-items: flex-start;
    }

    @include mobile-only {
      text-align: center;
      
      p {
        margin-right: 0;
      }
    }
  }

  .cta-wrapper {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    justify-content: center;

    @include tablet {
      justify-content: flex-start;
    }
  }

  .cta-button {
    display: inline-block;
    padding: var(--spacing-md) var(--spacing-md);
    background-color: var(--color-primary);
    color: var(--color-bg);
    text-decoration: none;
    font-weight: var(--font-weight-bold);
    border-radius: 5rem;
    box-shadow: 0 0.625rem 1.25rem var(--color-shadow);
    transition:
      transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
      background-color 0.3s ease;

    &:hover {
      transform: translateY(-0.5rem) scale(1.02);
      background-color: var(--color-primary);
    }

    .social-icon {
      width: 1.5rem;
      height: 1.5rem;
      object-fit: contain;
      filter: var(--icon-filter);
    }
  }

  .visual-wrapper {
    position: relative;
    height: 25rem;
    display: flex;
    justify-content: center;
    align-items: center;

    @include tablet {
      height: 40rem;
    }
  }

  .bubble-large {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    flex-direction: column;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background-color: var(--color-primary);
    animation: float 12s ease-in-out infinite;

    h1,
    p {
      width: 80%;
      padding-left: 3rem;
      color: var(--color-bg);
      line-height: var(--line-height-tight);
      letter-spacing: -0.03em;
      font-size: var(--font-size-xl);
      font-weight: 200;
    }

    h1 {
      letter-spacing: -0.05em;
      font-size: var(--font-size-3xl);
      line-height: 0.75;
    }

    @include tablet {
      width: 25rem;
      height: 25rem;
    }

    @include mobile-only {
      h1, p {
        width: 100%;
      }
    }
  }

  .bubble {
    position: absolute;
    border-radius: 50%;
    backdrop-filter: blur(0.25rem);
    width: var(--size, 5rem);
    height: var(--size, 5rem);
    background-color: var(--color, var(--color-secondary));
    animation: float var(--speed, 10s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    z-index: -1;
  }

  @keyframes float {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }

    33% {
      transform: translate(2rem, -2rem) rotate(5deg);
    }

    66% {
      transform: translate(-1.5rem, 2rem) rotate(-5deg);
    }
  }
</style>

<script>
  const randomizeBubbles = () => {
    const bubbles = Array.from(document.querySelectorAll('.bubble'))
    const colors = [
      'var(--color-secondary)',
      'var(--color-tertiary)',
      'var(--color-quaternary)',
    ]

    // Create a shuffled list of corners to ensure each 
    // bubble gets a unique quadrant and avoids overlap
    const corners = [
      { vertical: 'top', horizontal: 'left' },
      { vertical: 'top', horizontal: 'right' },
      { vertical: 'bottom', horizontal: 'left' },
      { vertical: 'bottom', horizontal: 'right' },
    ].sort(() => Math.random() - 0.5)

    bubbles.forEach((bubble, index) => {
      // Random aesthetic properties
      const size = Math.floor(Math.random() * 8 + 4) + 'rem'
      const speed = Math.floor(Math.random() * 12 + 8) + 's'
      const delay = Math.floor(Math.random() * 6) * -1 + 's'
      const color = colors[Math.floor(Math.random() * colors.length)]

      // Assign a unique quadrant based on index
      const corner = corners[index % corners.length]

      // Random values for peripheral but safe interior (from 2% to 10%)
      const vVal = Math.floor(Math.random() * 8 + 2) + '%'
      const hVal = Math.floor(Math.random() * 8 + 2) + '%'

      // Apply to bubble
      const b = bubble as HTMLElement
      b.style.setProperty('--size', size)
      b.style.setProperty('--speed', speed)
      b.style.setProperty('--delay', delay)
      b.style.setProperty('--color', color)

      // Reset all positioning styles first
      b.style.top = 'auto'
      b.style.bottom = 'auto'
      b.style.left = 'auto'
      b.style.right = 'auto'

      // Apply new safe position in its unique quadrant
      b.style.setProperty(corner.vertical, vVal)
      b.style.setProperty(corner.horizontal, hVal)
    })
  }

  // Initialize on load
  randomizeBubbles()
</script>
