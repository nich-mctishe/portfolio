---
import { getEntry } from 'astro:content'
import Section from './Section.astro'

const highlightsEntry = await getEntry('career-highlights', 'data')
const highlights = (highlightsEntry?.data?.['career-highlights'] || [])
  .filter((item: any) => item.active !== false)
---

<Section id="career-highlights" class="highlights-section">
  <div class="section-header">
    <h2 class="section-title">Career Highlights</h2>
    <div class="title-underline"></div>
  </div>

  <div class="highlights-container">
    <ul class="highlights-list">
      {
        highlights.map((item: any, index: number) => (
          <li class="highlight-item reveal">
            <div class="highlight-icon">
              <svg 
                viewBox="0 0 24 24" 
                width="24" 
                height="24" 
                stroke="currentColor" 
                stroke-width="3" 
                fill="none" 
                stroke-linecap="round" 
                stroke-linejoin="round"
              >
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </div>
            <p class="highlight-text">{item.highlight}</p>
          </li>
        ))
      }
    </ul>
  </div>
</Section>

<style lang="scss">
  @use "../styles/mixins" as *;

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-title {
    @include main-title;

    margin-bottom: var(--spacing-sm);
  }

  .title-underline {
    width: 3.5rem;
    height: 0.25rem;
    background: var(--color-primary);
    margin: 0 auto;
    border-radius: 1rem;
  }

  .highlights-container {
    max-width: 60rem;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .highlights-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    padding: 0;
    list-style: none;
  }

  .highlight-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) 0;
    transition: transform 0.3s ease;

    &:hover {
      transform: translateX(0.5rem);

      .highlight-icon {
        color: var(--color-secondary);
        transform: scale(1.1);
      }
    }
  }

  .highlight-icon {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    color: var(--color-primary);
    transition: all 0.3s ease;
    padding-top: 0.125rem;
  }

  .highlight-text {
    @include body-text(var(--font-size-md));

    margin: 0;
    line-height: var(--line-height-semi-loose);
  }

  @include mobile-only {
    .highlights-container {
      padding: 0 var(--spacing-sm);
    }

    .highlight-item {
      gap: var(--spacing-sm);
      padding: var(--spacing-xs) 0;
    }
    
    .highlight-icon {
      width: 1.5rem;
      height: 1.5rem;
      
      svg {
        width: 1.25rem;
        height: 1.25rem;
      }
    }
  }
</style>
