{
  "name": "portfolio",
  "type": "module",
  "version": "0.0.1",
  "description": "Personal portfolio website — statically generated with Astro",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint . && stylelint \"**/*.{css,scss,astro}\"",
    "format": "eslint --fix . && stylelint \"**/*.{css,scss,astro}\" --fix",
    "test": "vitest",
    "test:e2e": "start-server-and-test dev http://localhost:4321 test:e2e:run",
    "test:e2e:ci": "start-server-and-test preview http://localhost:4321/ test:e2e:run",
    "test:e2e:run": "NODE_OPTIONS='--import tsx' cucumber-js -c tests/e2e/cucumber.js",
    "test:vrt": "playwright test -c playwright.config.ts",
    "test:vrt:update": "playwright test -c playwright.config.ts --update-snapshots",
    "test:a11y": "start-server-and-test dev http://localhost:4321 test:a11y:run",
    "test:a11y:ci": "start-server-and-test preview http://localhost:4321/ test:a11y:run",
    "test:a11y:run": "NODE_OPTIONS='--import tsx' node tests/a11y/homepage.a11y.ts",
    "docker:vrt:build": "docker build -t portfolio-vrt .",
    "docker:vrt:update": "docker run --rm -v $(pwd):/work -v /work/node_modules -v /work/dist portfolio-vrt pnpm test:vrt:update",
    "docker:vrt:run": "docker run --rm -v $(pwd):/work -v /work/node_modules -v /work/dist portfolio-vrt pnpm test:vrt",
    "test:all": "pnpm run test --run && pnpm run test:e2e && pnpm run docker:vrt:run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource-variable/open-sans": "^5.2.7",
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@axe-core/cli": "^4.11.3",
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "happy-dom": "^20.7.0",
    "postcss-html": "^1.8.1",
    "previewjs": "^1.0.6",
    "sass": "^1.97.3",
    "serve": "^14.2.3",
    "start-server-and-test": "^3.0.2",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  },
  "packageManager": "pnpm@10.29.1"
}